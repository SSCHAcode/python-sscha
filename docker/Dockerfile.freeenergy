FROM sscha-cuda

RUN conda run -n sscha pip install --no-cache-dir nequip openequivariance

RUN mkdir -p /opt/nequip

# Model is compiled on first launch (requires GPU at runtime, not build time)
ENV NEQUIP_MODEL_PATH=/opt/nequip/NequIP-OAM-XL.nequip.pt2

COPY docker/entrypoint-freeenergy.sh /usr/local/bin/entrypoint-freeenergy.sh
RUN chmod +x /usr/local/bin/entrypoint-freeenergy.sh

ENTRYPOINT ["/usr/local/bin/entrypoint-freeenergy.sh"]
CMD ["/bin/bash"]
